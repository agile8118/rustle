  "query": "SELECT c.id, c.column_id, c.title, c.description, c.position, c.due_at, c.created_at\n         FROM cards c\n         JOIN board_columns bc ON bc.id = c.column_id\n         JOIN boards b ON b.id = bc.board_id\n         WHERE c.id = $1 AND b.owner_id = $2",
